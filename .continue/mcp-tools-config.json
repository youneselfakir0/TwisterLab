{
  "$schema": "https://docs.continue.dev/schemas/mcp-tools-config.json",
  "version": "1.0.0",
  "description": "TwisterLab MCP Tools Configuration - Policies de sécurité et activation",
  
  "servers": [
    {
      "name": "TwisterLab MCP",
      "apiBase": "http://192.168.0.30:8000/v1/mcp/tools",
      "enabled": true,
      "description": "7 agents autonomes TwisterLab en production",
      
      "tools": [
        {
          "name": "monitor_system_health",
          "displayName": "🔍 Monitor System Health",
          "agent": "RealMonitoringAgent",
          "description": "Surveillance système (CPU, RAM, disque, Docker services)",
          "endpoint": "/monitor_system_health",
          "method": "POST",
          "policy": "automatic",
          "enabled": true,
          "capabilities": [
            "cpu_monitoring",
            "ram_monitoring",
            "disk_monitoring",
            "docker_health"
          ],
          "inputSchema": {
            "type": "object",
            "properties": {
              "include_docker": {
                "type": "boolean",
                "description": "Include Docker service health checks",
                "default": true
              },
              "threshold_cpu_percent": {
                "type": "number",
                "description": "CPU usage alert threshold (0-100)",
                "default": 80
              },
              "threshold_memory_percent": {
                "type": "number",
                "description": "Memory usage alert threshold (0-100)",
                "default": 90
              },
              "threshold_disk_percent": {
                "type": "number",
                "description": "Disk usage alert threshold (0-100)",
                "default": 85
              }
            }
          },
          "outputFormat": {
            "cpu": "object",
            "memory": "object",
            "disk": "object",
            "docker_services": "array",
            "alerts": "array",
            "timestamp": "string"
          }
        },
        
        {
          "name": "create_backup",
          "displayName": "💾 Create Backup",
          "agent": "RealBackupAgent",
          "description": "Backup automatisé (PostgreSQL, Redis, configs) avec disaster recovery",
          "endpoint": "/create_backup",
          "method": "POST",
          "policy": "ask",
          "enabled": true,
          "capabilities": [
            "postgres_backup",
            "redis_backup",
            "config_backup",
            "incremental_backup"
          ],
          "inputSchema": {
            "type": "object",
            "properties": {
              "backup_type": {
                "type": "string",
                "enum": ["full", "incremental", "differential"],
                "description": "Type de backup à créer",
                "default": "incremental"
              },
              "targets": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["database", "redis", "configs", "all"]
                },
                "description": "Cibles du backup",
                "default": ["all"]
              },
              "compression": {
                "type": "boolean",
                "description": "Compresser les backups",
                "default": true
              },
              "encryption": {
                "type": "boolean",
                "description": "Chiffrer les backups sensibles",
                "default": true
              }
            }
          },
          "outputFormat": {
            "backup_id": "string",
            "files": "array",
            "size_bytes": "number",
            "duration_seconds": "number",
            "checksum": "string",
            "location": "string"
          }
        },
        
        {
          "name": "sync_cache",
          "displayName": "🔄 Sync Cache",
          "agent": "RealSyncAgent",
          "description": "Synchronisation Redis ⇄ PostgreSQL avec résolution de conflits",
          "endpoint": "/sync_cache",
          "method": "POST",
          "policy": "automatic",
          "enabled": true,
          "capabilities": [
            "redis_sync",
            "postgres_sync",
            "conflict_resolution"
          ],
          "inputSchema": {
            "type": "object",
            "properties": {
              "direction": {
                "type": "string",
                "enum": ["redis_to_db", "db_to_redis", "bidirectional"],
                "description": "Direction de synchronisation",
                "default": "bidirectional"
              },
              "keys_pattern": {
                "type": "string",
                "description": "Pattern Redis (ex: 'ticket:*', 'agent:*')",
                "default": "*"
              },
              "conflict_resolution": {
                "type": "string",
                "enum": ["latest_wins", "manual", "merge"],
                "description": "Stratégie de résolution de conflits",
                "default": "latest_wins"
              }
            }
          },
          "outputFormat": {
            "synced_keys": "number",
            "conflicts": "number",
            "errors": "array",
            "duration_ms": "number"
          }
        },
        
        {
          "name": "classify_ticket",
          "displayName": "🎯 Classify Ticket",
          "agent": "RealClassifierAgent",
          "description": "Classification de tickets avec Ollama LLM (llama3.2:1b)",
          "endpoint": "/classify_ticket",
          "method": "POST",
          "policy": "automatic",
          "enabled": true,
          "capabilities": [
            "llm_classification",
            "confidence_scoring",
            "priority_assignment"
          ],
          "categories": [
            "network",
            "hardware",
            "software",
            "account",
            "email"
          ],
          "inputSchema": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "title": {
                "type": "string",
                "description": "Titre du ticket",
                "minLength": 5
              },
              "description": {
                "type": "string",
                "description": "Description détaillée du problème",
                "minLength": 10
              },
              "user_email": {
                "type": "string",
                "description": "Email de l'utilisateur (optionnel)"
              },
              "llm_model": {
                "type": "string",
                "enum": ["llama3.2:1b", "llama3:latest"],
                "description": "Modèle LLM à utiliser",
                "default": "llama3.2:1b"
              }
            }
          },
          "outputFormat": {
            "ticket_id": "string",
            "category": "string",
            "priority": "string",
            "confidence": "number",
            "reasoning": "string",
            "suggested_agent": "string"
          }
        },
        
        {
          "name": "resolve_ticket",
          "displayName": "✅ Resolve Ticket",
          "agent": "RealResolverAgent",
          "description": "Résolution de tickets via SOPs (network, hardware, software, account, email)",
          "endpoint": "/resolve_ticket",
          "method": "POST",
          "policy": "ask",
          "enabled": true,
          "capabilities": [
            "sop_execution",
            "troubleshooting",
            "guided_resolution"
          ],
          "inputSchema": {
            "type": "object",
            "required": ["ticket_id"],
            "properties": {
              "ticket_id": {
                "type": "string",
                "description": "ID du ticket à résoudre"
              },
              "category": {
                "type": "string",
                "enum": ["network", "hardware", "software", "account", "email"],
                "description": "Catégorie du ticket (optionnel si déjà classifié)"
              },
              "auto_execute": {
                "type": "boolean",
                "description": "Exécuter automatiquement les SOPs",
                "default": false
              },
              "steps_override": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Étapes SOP personnalisées (optionnel)"
              }
            }
          },
          "outputFormat": {
            "ticket_id": "string",
            "status": "string",
            "sop_executed": "string",
            "steps_completed": "array",
            "resolution_time_seconds": "number",
            "success": "boolean",
            "notes": "string"
          }
        },
        
        {
          "name": "execute_desktop_command",
          "displayName": "🖥️ Execute Desktop Command",
          "agent": "RealDesktopCommanderAgent",
          "description": "Exécution de commandes système distantes (PowerShell, Bash, SSH)",
          "endpoint": "/execute_desktop_command",
          "method": "POST",
          "policy": "ask",
          "enabled": true,
          "security": "whitelisted_commands_only",
          "capabilities": [
            "powershell_execution",
            "bash_execution",
            "ssh_commands",
            "command_whitelisting"
          ],
          "inputSchema": {
            "type": "object",
            "required": ["command", "target_host"],
            "properties": {
              "command": {
                "type": "string",
                "description": "Commande à exécuter (whitelist uniquement)"
              },
              "target_host": {
                "type": "string",
                "description": "Hostname ou IP cible"
              },
              "shell": {
                "type": "string",
                "enum": ["powershell", "bash", "ssh"],
                "description": "Type de shell",
                "default": "powershell"
              },
              "timeout_seconds": {
                "type": "number",
                "description": "Timeout d'exécution",
                "default": 30
              },
              "credentials_tier": {
                "type": "string",
                "enum": ["enterprise", "personal"],
                "description": "Tier de credentials",
                "default": "enterprise"
              }
            }
          },
          "outputFormat": {
            "stdout": "string",
            "stderr": "string",
            "exit_code": "number",
            "duration_seconds": "number",
            "host": "string"
          }
        },
        
        {
          "name": "list_autonomous_agents",
          "displayName": "📋 List Autonomous Agents",
          "agent": "Registry",
          "description": "Liste tous les agents TwisterLab disponibles avec leur statut",
          "endpoint": "/list_autonomous_agents",
          "method": "GET",
          "policy": "automatic",
          "enabled": true,
          "capabilities": [
            "agent_registry",
            "status_monitoring"
          ],
          "inputSchema": {
            "type": "object",
            "properties": {}
          },
          "outputFormat": {
            "version": "string",
            "total": "number",
            "agents": "array",
            "infrastructure": "object",
            "api_base": "string"
          }
        }
      ]
    }
  ],
  
  "policies": {
    "automatic": {
      "description": "S'exécute automatiquement sans demander confirmation",
      "color": "#00FF00",
      "icon": "✅"
    },
    "ask": {
      "description": "Demande confirmation avant l'exécution",
      "color": "#FFA500",
      "icon": "⚠️"
    },
    "disabled": {
      "description": "Outil désactivé, ne peut pas être utilisé",
      "color": "#FF0000",
      "icon": "❌"
    }
  },
  
  "security": {
    "authentication": "hybrid",
    "encryption": "TLS",
    "audit_logging": true,
    "command_whitelisting": true,
    "credentials_vault": "encrypted"
  },
  
  "metadata": {
    "created": "2025-11-12T13:50:00Z",
    "last_updated": "2025-11-12T13:50:00Z",
    "api_version": "v1",
    "mcp_protocol": "2024-11-05",
    "total_tools": 7,
    "enabled_tools": 7
  }
}
