# Production Environment Configuration
# Copy this file to .env.prod and update values for your environment

# Application
ENVIRONMENT=production
DOMAIN_NAME=localhost
ADMIN_EMAIL=admin@twisterlab.local

# Security
SECRET_KEY_FILE=/run/secrets/jwt_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_FILE=/run/secrets/admin_password
ALLOWED_ORIGINS=http://localhost,http://localhost:8000,http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_PER_MINUTE=100

# Database
POSTGRES_DB=twisterlab
POSTGRES_USER=twisterlab
POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
DATABASE_URL=postgresql://twisterlab@postgres:5432/twisterlab

# Redis
REDIS_PASSWORD_FILE=/run/secrets/redis_password
REDIS_URL=redis://:password@redis:6379/0

# AI/Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/twisterlab.log

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_HOST=0.0.0.0
API_PORT=8000

# Monitoring
PROMETHEUS_ENABLED=true
