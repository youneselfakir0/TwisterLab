# TwisterLab Production Environment Variables
# Copy this file to .env.production and update with production credentials
# IMPORTANT: Never commit .env.production to version control!

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
POSTGRES_USER=twisterlab
POSTGRES_PASSWORD=_PRODUCTION_POSTGRES_PASSWORD_CHANGE_ME_
POSTGRES_DB=twisterlab
DATABASE_URL=postgresql+asyncpg://twisterlab:_PRODUCTION_POSTGRES_PASSWORD_CHANGE_ME_@postgres:5432/twisterlab

# ============================================================================
# REDIS
# ============================================================================
REDIS_PASSWORD=_PRODUCTION_REDIS_PASSWORD_CHANGE_ME_
REDIS_URL=redis://:_PRODUCTION_REDIS_PASSWORD_CHANGE_ME_@redis:6379/0

# ============================================================================
# OLLAMA (LLM)
# ============================================================================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:latest

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=_PRODUCTION_SECRET_KEY_MIN_32_CHARS_CHANGE_ME_
ALLOWED_ORIGINS=https://twisterlab.yourdomain.com,https://api.twisterlab.yourdomain.com

# ============================================================================
# MONITORING
# ============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# GRAFANA
# ============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=_PRODUCTION_GRAFANA_PASSWORD_CHANGE_ME_
GRAFANA_ROOT_URL=https://grafana.twisterlab.yourdomain.com

# ============================================================================
# OPENWEBUI (Optional Frontend)
# ============================================================================
OPENAI_API_KEY=production_api_key_if_needed

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
# All agents use the same model by default
CLASSIFIER_MODEL=deepseek-r1:latest
RESOLVER_MODEL=deepseek-r1:latest
DESKTOP_COMMANDER_MODEL=deepseek-r1:latest
MAESTRO_MODEL=deepseek-r1:latest

# Agent-specific settings
CLASSIFIER_TEMPERATURE=0.2
RESOLVER_TEMPERATURE=0.3
DESKTOP_COMMANDER_TEMPERATURE=0.1
MAESTRO_TEMPERATURE=0.3

# ============================================================================
# PERFORMANCE TUNING (Production Optimized)
# ============================================================================
MAX_CONCURRENT_TICKETS=100
TICKET_TIMEOUT_SECONDS=300
SYNC_INTERVAL_SECONDS=300
BACKUP_INTERVAL_SECONDS=21600
MONITORING_INTERVAL_SECONDS=60

# Connection pools
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# ALERT THRESHOLDS (Production Stricter)
# ============================================================================
ALERT_CPU_THRESHOLD=75.0
ALERT_MEMORY_THRESHOLD=80.0
ALERT_DISK_THRESHOLD=85.0
ALERT_API_RESPONSE_TIME=1.5
ALERT_ERROR_RATE=5.0
ALERT_AGENT_RESPONSE_TIME=3.0

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=90
BACKUP_S3_BUCKET=twisterlab-backups-production
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=_AWS_ACCESS_KEY_CHANGE_ME_
AWS_SECRET_ACCESS_KEY=_AWS_SECRET_KEY_CHANGE_ME_

# ---------------------------------------------------------------------------
# Retention worker (auto-start). When set to true, RealBackupAgent will start a background retention worker
# on initialization. `TWISTERLAB_RETENTION_INTERVAL` controls the periodic interval (in seconds).
TWISTERLAB_START_RETENTION=false
TWISTERLAB_RETENTION_INTERVAL=3600
# Monitoring: When retention is enabled, monitor these metrics in Prometheus:
# - backup_retention_runs_total
# - backup_retention_removed_total

# ============================================================================
# LOGGING
# ============================================================================
LOG_FORMAT=json
LOG_FILE=/app/logs/twisterlab.log
LOG_MAX_SIZE=100M
LOG_BACKUP_COUNT=10

# ============================================================================
# SECURITY
# ============================================================================
# CORS settings
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=120

# Session management
SESSION_TIMEOUT=3600
SESSION_SECRET=_PRODUCTION_SESSION_SECRET_CHANGE_ME_

# ============================================================================
# HIGH AVAILABILITY (Optional)
# ============================================================================
# Load balancer health check
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30

# Replication (if using PostgreSQL streaming replication)
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_REPLICA_PORT=5432

# Redis Sentinel (if using Redis HA)
REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379,sentinel3:26379
REDIS_SENTINEL_MASTER=twisterlab-master
