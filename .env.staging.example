# TwisterLab Staging Environment Variables
# Copy this file to .env.staging and update with your values

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_PASSWORD=staging_secure_password_CHANGE_ME
DATABASE_URL=postgresql+asyncpg://twisterlab_staging:staging_secure_password_CHANGE_ME@postgres:5432/twisterlab_staging

# ============================================================================
# REDIS
# ============================================================================
REDIS_PASSWORD=staging_redis_password_CHANGE_ME
REDIS_URL=redis://:staging_redis_password_CHANGE_ME@redis:6379/0

# ============================================================================
# OLLAMA
# ============================================================================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:latest

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
SECRET_KEY=staging_secret_key_CHANGE_ME_IN_PRODUCTION
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://openwebui:8080

# ============================================================================
# MONITORING
# ============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# GRAFANA
# ============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=staging_grafana_password_CHANGE_ME

# ============================================================================
# OPENWEBUI
# ============================================================================
OPENAI_API_KEY=staging_dummy_key

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
CLASSIFIER_MODEL=deepseek-r1:latest
RESOLVER_MODEL=deepseek-r1:latest
DESKTOP_COMMANDER_MODEL=deepseek-r1:latest
MAESTRO_MODEL=deepseek-r1:latest

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
MAX_CONCURRENT_TICKETS=50
TICKET_TIMEOUT_SECONDS=300
SYNC_INTERVAL_SECONDS=300
BACKUP_INTERVAL_SECONDS=21600
MONITORING_INTERVAL_SECONDS=60

# ============================================================================
# ALERT THRESHOLDS
# ============================================================================
ALERT_CPU_THRESHOLD=80.0
ALERT_MEMORY_THRESHOLD=85.0
ALERT_DISK_THRESHOLD=90.0
ALERT_API_RESPONSE_TIME=2.0
ALERT_ERROR_RATE=10.0
ALERT_AGENT_RESPONSE_TIME=5.0
