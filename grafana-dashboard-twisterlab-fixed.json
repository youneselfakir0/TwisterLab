{
  "dashboard": {
    "id": null,
    "title": "TwisterLab - Complete Monitoring Dashboard",
    "tags": ["twisterlab", "monitoring", "agents"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "CPU Usage",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "df3y4j46jk4qoc"
        },
        "targets": [
          {
            "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "CPU Usage %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1}
      },
      {
        "id": 3,
        "title": "Memory Usage",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "df3y4j46jk4qoc"
        },
        "targets": [
          {
            "expr": "100 - ((node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)",
            "legendFormat": "Memory Usage %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1}
      },
      {
        "id": 4,
        "title": "Disk Usage",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "df3y4j46jk4qoc"
        },
        "targets": [
          {
            "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100",
            "legendFormat": "Root /",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9}
      },
      {
        "id": 5,
        "title": "Network I/O",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "df3y4j46jk4qoc"
        },
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{device=\"enp0s31f6\"}[5m])",
            "legendFormat": "RX",
            "refId": "A"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total{device=\"enp0s31f6\"}[5m])",
            "legendFormat": "TX",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9}
      },
      {
        "id": 6,
        "title": "Services Health",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17}
      },
      {
        "id": 7,
        "title": "Exporters Status",
        "type": "table",
        "datasource": {
          "type": "prometheus",
          "uid": "df3y4j46jk4qoc"
        },
        "targets": [
          {
            "expr": "up",
            "legendFormat": "{{job}} ({{instance}})",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "center"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Value"
              },
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "0": {
                          "text": "DOWN",
                          "color": "red"
                        },
                        "1": {
                          "text": "UP",
                          "color": "green"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 18}
      },
