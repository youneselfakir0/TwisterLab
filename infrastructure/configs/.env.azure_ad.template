# =============================================================================
# AZURE AD AUTHENTICATION CONFIGURATION
# =============================================================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to version control!

# Azure AD Application Registration
# Get these from Azure Portal > Azure AD > App registrations
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# API Configuration
API_HOST=192.168.0.30  # Production: edgeserver IP
# API_HOST=localhost    # Staging: local development

# Authentication Settings
AUTH_ENABLED=true
AUTH_PROVIDER=azure_ad  # Options: azure_ad, local, none

# OAuth2 Redirect URIs (must match Azure AD app registration)
# Production: http://192.168.0.30:8000/auth/callback
# Staging: http://localhost:8000/auth/callback
