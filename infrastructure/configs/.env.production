# =============================================================================
# TWISTERLAB PRODUCTION ENVIRONMENT
# Date: 2025-11-10
# Description: Configuration pour environnement de production
# AVERTISSEMENT: NE JAMAIS COMMITER CE FICHIER AVEC LES VRAIS MOTS DE PASSE !
# =============================================================================

# Environment Type
ENVIRONMENT=production

# Domain Configuration
DOMAIN=twisterlab.local

# API Configuration
API_REPLICAS=2
VERSION=latest

# Database Configuration (PostgreSQL)
POSTGRES_DB=twisterlab_prod
POSTGRES_USER=twisterlab
POSTGRES_PASSWORD=twisterlab_prod_db_password_2024!

# Redis Configuration
REDIS_PASSWORD=twisterlab_prod_redis_password_2024!

# Security Keys (GÉNÉRER DES CLÉS FORTES EN PRODUCTION !)
# Utiliser: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_PRODUCTION_SECRET_KEY_MIN_32_CHARS_STRONG!
WEBUI_SECRET_KEY=CHANGE_ME_PRODUCTION_WEBUI_SECRET_KEY_2024!

# Data Storage Path
DATA_PATH=/twisterlab/ai-storage/data

# Ollama Configuration (Remote GPU Server)
OLLAMA_BASE_URL=http://192.168.0.20:11434
OLLAMA_TIMEOUT=60

# Logging
LOG_LEVEL=INFO

# Ports
WEBUI_PORT=8083

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_DEBUG=false
