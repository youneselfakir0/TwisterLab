{
  "dashboard": {
    "title": "TwisterLab Overview",
    "tags": [
      "twisterlab",
      "overview"
    ],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "type": "graph",
        "title": "System CPU Usage",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "system_cpu_usage_percent",
            "legendFormat": "CPU Usage %"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "max": 100
          },
          {
            "format": "short"
          }
        ]
      },
      {
        "id": 2,
        "type": "graph",
        "title": "System Memory Usage",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "system_memory_usage_percent",
            "legendFormat": "Memory Usage %"
          }
        ],
        "yaxes": [
          {
            "format": "percent",
            "max": 100
          },
          {
            "format": "short"
          }
        ]
      },
      {
        "id": 3,
        "type": "graph",
        "title": "Agent Response Times",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(agent_maestro_response_time_ms[5m])",
            "legendFormat": "Maestro"
          },
          {
            "expr": "rate(agent_classifier_response_time_ms[5m])",
            "legendFormat": "Classifier"
          },
          {
            "expr": "rate(agent_resolver_response_time_ms[5m])",
            "legendFormat": "Resolver"
          }
        ],
        "yaxes": [
          {
            "format": "ms"
          },
          {
            "format": "short"
          }
        ]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "API Requests Total",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(rate(api_requests_total[5m]))",
            "legendFormat": "Requests/sec"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      }
    ]
  },
  "overwrite": true
}